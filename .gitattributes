# Auto detect text files and perform LF normalization
*           text=auto
*.java      text eol=lf
*.xml       text eol=lf
*.properties text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.sh        text eol=lf
*.cmd       text eol=crlf
mvnw        text eol=lf
Dockerfile  text eol=lf
.env.example    text eol=lf
*.sh            text eol=lf
scripts/*       text eol=lf