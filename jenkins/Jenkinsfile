pipeline {
    agent any

    tools {
        maven 'Maven'
    }

    environment {
        APP_NAME  = 'transaction-service'
        IMAGE_NAME = "securefinops/${APP_NAME}"
        IMAGE_TAG  = "${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                echo "Checked out branch: ${env.BRANCH_NAME}"
            }
        }

        stage('IaC Scan - Checkov') {
            steps {
                script {
                    def status = sh(
                        script: """
                            docker run --rm \
                                --volumes-from securefinops-jenkins-local \
                                bridgecrew/checkov:latest \
                                --directory ${WORKSPACE}/infra \
                                --output json \
                                --soft-fail \
                                --quiet \
                                > ${WORKSPACE}/checkov-results.json 2>/dev/null || true

                            echo "File size: \$(wc -c < ${WORKSPACE}/checkov-results.json 2>/dev/null || echo 0) bytes"
                        """,
                        returnStatus: true
                    )
                    env.CHECKOV_STATUS = (status == 0) ? '<span style="color:green;font-weight:bold;">PASSED</span>' : '<span style="color:red;font-weight:bold;">FAILED</span>'
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'checkov-results.json',
                                    allowEmptyArchive: true
                }
            }
        }

        stage('Secret Scan - Gitleaks') {
            steps {
                script {
                    def status = sh(
                        script: '''
                            docker run --rm \
                                --volumes-from securefinops-jenkins-local \
                                zricethezav/gitleaks:latest \
                                detect \
                                    --source ${WORKSPACE} \
                                    --no-git \
                                    --report-format json \
                                    --report-path ${WORKSPACE}/gitleaks-results.json \
                                    --exit-code 0 \
                                    --verbose
                        ''',
                        returnStatus: true
                    )
                    env.GITLEAKS_STATUS = (status == 0) ? '<span style="color:green;font-weight:bold;">PASSED</span>' : '<span style="color:red;font-weight:bold;">FAILED</span>'
                }
                
            }
            post {
                always {
                    archiveArtifacts artifacts: 'gitleaks-results.json',
                                    allowEmptyArchive: true
                }
            }
        }

        stage('Build JAR') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Unit Tests') {
            steps {
                    withCredentials([
                    string(credentialsId: 'DB_USER', variable: 'DB_USER'),
                    string(credentialsId: 'DB_PASSWORD', variable: 'DB_PASSWORD')
                ]) {
                    sh '''
                        mvn test \
                            -Dspring.datasource.url=jdbc:postgresql://securefinops-postgres-local:5432/transactiondb \
                            -Dspring.datasource.username=${DB_USER} \
                            -Dspring.datasource.password=${DB_PASSWORD}
                    '''
                }
            }
            post {
                always {
                    junit '**/target/surefire-reports/*.xml'
                }
            }
        }

        stage('SAST - SonarQube') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh '''
                        mvn sonar:sonar \
                            -Dsonar.projectKey=securefinops-transaction-service \
                            -Dsonar.projectName="SecureFinOps Transaction Service" \
                            -Dsonar.java.binaries=target/classes
                    '''
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Pull Security Images') {
            steps {
                sh '''
                    docker pull semgrep/semgrep:latest
                    docker pull aquasec/trivy:latest
                '''
            }
        }

        stage('SAST - Semgrep') {
            steps {
                sh """
                    docker run --rm \
                        --volumes-from securefinops-jenkins-local \
                        semgrep/semgrep:latest \
                        semgrep scan \
                            --config p/java \
                            --config p/owasp-top-ten \
                            --config p/secrets \
                            --json \
                            --output ${WORKSPACE}/semgrep-results.json \
                            ${WORKSPACE}
                """
            }
            post {
                always {
                    archiveArtifacts artifacts: 'semgrep-results.json',
                                    allowEmptyArchive: true
                }
            }
        }

        stage('SCA - Trivy Filesystem') {
            steps {
                sh """
                    docker run --rm \
                        --volumes-from securefinops-jenkins-local \
                        -v trivy-cache:/root/.cache/trivy \
                        -e TRIVY_OFFLINE_SCAN=true \
                        aquasec/trivy:latest \
                        fs \
                            --format json \
                            --output ${WORKSPACE}/trivy-fs-results.json \
                            --severity HIGH,CRITICAL \
                            ${WORKSPACE}
                """
            }
        }

        stage('Build Docker Image') {
            steps {
                sh """
                    docker build \
                        -t ${IMAGE_NAME}:${IMAGE_TAG} \
                        -t ${IMAGE_NAME}:latest \
                        .
                """
            }
        }

        stage('Image Scan - Trivy') {
            steps {
                sh """
                    docker run --rm \
                        -v /var/run/docker.sock:/var/run/docker.sock \
                        -v trivy-cache:/root/.cache/trivy \
                        aquasec/trivy:latest \
                        image \
                            --format json \
                            --severity HIGH,CRITICAL \
                            --exit-code 0 \
                            --quiet \
                            ${IMAGE_NAME}:${IMAGE_TAG} > ${WORKSPACE}/trivy-image-results.json 2>/dev/null
                    
                    echo "File size: \$(wc -c < ${WORKSPACE}/trivy-image-results.json) bytes"
                    
                    CRITICAL=\$(grep -c '"Severity": "CRITICAL"' ${WORKSPACE}/trivy-image-results.json || echo 0)
                    echo "Critical vulnerabilities found: \$CRITICAL"
                """
            }
            post {
                always {
                    archiveArtifacts artifacts: 'trivy-image-results.json',
                                    allowEmptyArchive: true
                }
            }
        }

        stage('Deploy Staging') {
            steps {
                withCredentials([
                    string(credentialsId: 'DB_USER', variable: 'DB_USER'),
                    string(credentialsId: 'DB_PASSWORD', variable: 'DB_PASSWORD')
                ]) { 
                    sh '''
                        docker stop ${APP_NAME}-staging || true
                        docker rm ${APP_NAME}-staging || true
                        docker run -d \
                            --name ${APP_NAME}-staging \
                            --network securefinops-network \
                            -p 8082:8080 \
                            -e DB_USER=${DB_USER} \
                            -e DB_PASSWORD=${DB_PASSWORD} \
                            -e SPRING_DATASOURCE_URL=jdbc:postgresql://securefinops-postgres-local:5432/transactiondb \
                            ${IMAGE_NAME}:${IMAGE_TAG}
                    '''
                }
            }
        }

        stage('Health Check - staging') {
            steps {
                timeout(time: 2, unit: 'MINUTES') {
                    waitUntil(initialRecurrencePeriod: 5000) {
                        script {
                            def result = sh(
                                script: 'curl -sf http://transaction-service-staging:8080/actuator/health',
                                returnStatus: true
                            )
                            return result == 0
                        }
                    }
                }
            }
        }
    }

    post {
        success {
            echo """ Pipeline SUCCESS:
                IMAGE_NAME --- ${IMAGE_NAME}
                Build -------- ${BUILD_NUMBER}
                Commit ------- ${GIT_COMMIT}
                Branch ------- ${GIT_BRANCH}
            """
        }
        failure {
            echo """ Pipeline FAILED:
                IMAGE_NAME --- ${IMAGE_NAME}
                Build -------- ${BUILD_NUMBER}
                Commit ------- ${GIT_COMMIT}
                Branch ------- ${GIT_BRANCH}
            """
        }
        always {
            withCredentials([
                string(credentialsId: 'NOTIFICATION_EMAIL', variable: 'NOTIFICATION_EMAIL')
            ]) {
                emailext (
                    subject: "${currentBuild.result} - ${JOB_NAME} #${BUILD_NUMBER}",
                    body: """
                        <h2>Pipeline ${currentBuild.result} - Build: #${BUILD_NUMBER}</h2>
                        <p>Branch:<b> ${GIT_BRANCH}</b> - Commit:<b> ${GIT_COMMIT}</b></p>
                        <h3>Details:</h3>
                        <table border="1" cellpadding="5" cellspacing="0">
                            <tr><th>Stage</th><th>Status</th></tr>
                            <tr><td>Secret Scan - Gitleaks</td><td>${env.GITLEAKS_STATUS ?: 'N/A'}</td></tr>
                            <tr><td>IaC Scan - Checkov</td><td>${env.CHECKOV_STATUS ?: 'N/A'}</td></tr>
                        </table>
                    """,
                    mimeType: 'text/html',
                    to: "${NOTIFICATION_EMAIL}",
                    attachmentsPattern: 'semgrep-results.json,trivy-fs-results.json,trivy-image-results.json'
                )
            }
            /*cleanWs(
                cleanWhenSuccess: true,
                cleanWhenFailure: true,
                cleanWhenAborted: true,
                deleteDirs: true,
                notFailBuild: true,
                patterns: [[pattern: '.git', type: 'EXCLUDE']]
            )*/
        }
    }
}